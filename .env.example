# PostgreSQL (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=eris

# PostgreSQL connection string (used by Prisma / backend)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eris

# MongoDB (used by docker-compose)
MONGO_USER=root
MONGO_PASSWORD=rootpassword
MONGO_DB=eris

# MongoDB connection string (used by backend)
MONGO_URI=mongodb://root:rootpassword@localhost:27017/eris?authSource=admin

# PocketBase
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=admin@eris.local
POCKETBASE_ADMIN_PASSWORD=admin_password_123

# Backend server
PORT=4000
