# Backend server port
PORT=4000

# Frontend origin allowed by CORS
FRONTEND_URL="http://localhost:5173"

# PostgreSQL connection string (used by Prisma)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=<schema>PORT=4000
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/eris?schema=public"

# MongoDB Configuration
MONGO_URI="mongodb://root:rootpassword@127.0.0.1:27017/eris?authSource=admin"

# PocketBase Configuration
POCKETBASE_URL="http://127.0.0.1:8090"
POCKETBASE_ADMIN_EMAIL="admin@eris.local"
POCKETBASE_ADMIN_PASSWORD="admin_password_123"
